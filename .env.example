# Copy to .env on VPS:  cp .env.example .env

PORT=3000
HOST=0.0.0.0

# Protect EA + admin API (set a long random string)
API_KEY=change-me-to-random-secret

# Admin page login (http://IP:3000/admin)
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-admin-password

# ติดตั้งใหม่ยังไม่กดเปิด: ทดลองกี่วัน
INSTALL_TRIAL_DAYS=7
# กดเปิดแล้วใช้ตลอด (วันหมดอายุสำหรับ EA)
LIFETIME_EXPIRE_ISO=2099-12-31T23:59:59Z

# หน้าโปรโมต: ถือว่า EA ออนไลน์ถ้าเชื่อมต่อภายในกี่ชม.
ONLINE_HOURS=36

# หน้าดาวน์โหลด EA (วางไฟล์ที่ public/downloads/ หรือ URL ภายนอก)
EA_DOWNLOAD_URL=/downloads/Arbi_Gen5.ex5
EA_FILE_NAME=Arbi_Gen5.ex5
EA_DISPLAY_VERSION=1.00

# SQLite path (relative to this folder)
DATABASE_PATH=./data/platform.json
